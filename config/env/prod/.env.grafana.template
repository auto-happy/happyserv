# Grafana — Environnement Production
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD>
GRAFANA_DOMAIN=monitoring.happyserv.fr

# Authentication
GRAFANA_AUTH_ANONYMOUS_ENABLED=false
GRAFANA_AUTH_BASIC_ENABLED=true

# Database (optionnel — par défaut SQLite)
GRAFANA_DATABASE_TYPE=postgres
GRAFANA_DATABASE_HOST=postgres
GRAFANA_DATABASE_NAME=grafana
GRAFANA_DATABASE_USER=grafana
GRAFANA_DATABASE_PASSWORD=<GENERATE_PASSWORD>

# SMTP (notifications)
GRAFANA_SMTP_ENABLED=true
GRAFANA_SMTP_HOST=smtp.happyserv.fr:587
GRAFANA_SMTP_USER=grafana@happyserv.fr
GRAFANA_SMTP_PASSWORD=<GENERATE_SMTP_PASSWORD>
GRAFANA_SMTP_FROM=grafana@happyserv.fr
