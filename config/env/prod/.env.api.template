# API — Environnement Production
PORT=3000
NODE_ENV=production

# Base de données
DB_HOST=postgres
DB_PORT=5432
DB_USER=happyserv
DB_PASSWORD=<GENERATE_STRONG_PASSWORD>
DB_NAME=happyserv
DB_POOL_MIN=2
DB_POOL_MAX=20

# JWT
JWT_SECRET=<GENERATE_256BIT_SECRET>
JWT_REFRESH_SECRET=<GENERATE_256BIT_SECRET>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<GENERATE_REDIS_PASSWORD>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# SMTP
SMTP_HOST=smtp.happyserv.fr
SMTP_PORT=587
SMTP_USER=noreply@happyserv.fr
SMTP_PASS=<GENERATE_SMTP_PASSWORD>

# Audit
AUDIT_LOG_RETENTION_DAYS=365

# WebSocket
WS_PORT=3001

# CORS
CORS_ORIGIN=https://happyserv.fr,https://portal.happyserv.fr
