server {
    listen 80;
    server_name happyserv.fr www.happyserv.fr api.happyserv.fr portal.happyserv.fr;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name happyserv.fr www.happyserv.fr;

    # SSL
    ssl_certificate /etc/nginx/certs/happyserv/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/happyserv/privkey.pem;
    include /etc/nginx/snippets/ssl.conf;

    # Security headers
    include /etc/nginx/snippets/security-headers.conf;

    # Proxy vers Portal
    location / {
        proxy_pass http://portal:80;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
        proxy_buffering off;
    }
}

# API
server {
    listen 443 ssl http2;
    server_name api.happyserv.fr;

    ssl_certificate /etc/nginx/certs/happyserv/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/happyserv/privkey.pem;
    include /etc/nginx/snippets/ssl.conf;
    include /etc/nginx/snippets/security-headers.conf;

    # API
    include /etc/nginx/proxy/api.conf;

    # WebSocket
    include /etc/nginx/proxy/websocket.conf;
}

# Portal
server {
    listen 443 ssl http2;
    server_name portal.happyserv.fr;

    ssl_certificate /etc/nginx/certs/happyserv/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/happyserv/privkey.pem;
    include /etc/nginx/snippets/ssl.conf;
    include /etc/nginx/snippets/security-headers.conf;

    location / {
        proxy_pass http://portal:80;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
