server {
    listen 80;
    server_name telehappy.fr www.telehappy.fr telehappy.org www.telehappy.org;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name telehappy.fr www.telehappy.fr telehappy.org www.telehappy.org;

    # SSL
    ssl_certificate /etc/nginx/certs/telehappy/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/telehappy/privkey.pem;
    include /etc/nginx/snippets/ssl.conf;

    # Root
    root /var/www/telehappy;
    index index.html;

    # Security headers
    include /etc/nginx/snippets/security-headers.conf;

    # Rate limiting
    limit_req zone=download burst=20 nodelay;

    # Static files
    location / {
        try_files $uri $uri/ /index.html;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Assets
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Downloads
    location /download/ {
        alias /var/www/telehappy/download/;
        limit_req zone=download burst=20 nodelay;
    }

    # Health
    location /health {
        access_log off;
        return 200 "OK";
    }

    # Deny access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
}
